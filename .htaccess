RewriteEngine On

# Handle trailing slash added by Apache: serve slug.html if no index.html in that dir
RewriteCond %{REQUEST_FILENAME}index.html !-f
RewriteRule ^(.*)/$ /$1.html [L]

# Handle direct access without trailing slash
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]
